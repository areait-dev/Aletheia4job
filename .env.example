NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Storage CV)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

DATABASE_URL=postgresql://user:pass@localhost:5432/app?schema=public
DIRECT_URL=postgresql://user:pass@localhost:5432/app?schema=public

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

APP_ENCRYPTION_KEY=
SIGNED_STATE_SECRET=

CRONOFY_BASE_URL=https://api.cronofy.com
CRONOFY_CLIENT_ID=
CRONOFY_CLIENT_SECRET=
CRONOFY_REDIRECT_URI=http://localhost:3000/api/integrations/cronofy/callback
CRONOFY_TZID=Europe/Rome

DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_CLIENT_ID=

GROQ_API_KEY=
GEMINI_API_KEY=

# Inngest (background job queue per CV OCR + AI)
# Per sviluppo locale: INNGEST_DEV=1, poi esegui `npx inngest dev -u http://127.0.0.1:3000/api/inngest`
# In produzione su Vercel + Inngest Cloud: https://app.inngest.com (imposta INNGEST_SIGNING_KEY)
INNGEST_DEV=1
INNGEST_SERVE_ORIGIN=http://127.0.0.1:8288
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# Multiposting (feed XML per aggregatori)
AGGREGATOR_FEED_TOKEN=genera-un-token-casuale

# Webhook candidature in ingresso (secret condiviso via header X-Webhook-Secret o Authorization: Bearer)
MULTIPOSTING_WEBHOOK_SECRET=genera-un-secret-casuale

# LinkedIn Feed (richiede approvazione per agenzie). Tutte obbligatorie: se manca
# anche solo una, /api/linkedin-feed risponde 503 invece di generare un feed con dati finti.
LINKEDIN_FEED_ORG_ID=
LINKEDIN_COMPANY_ID=
LINKEDIN_JOB_POSTER_EMAIL=
LINKEDIN_COMPANY_NAME=
LINKEDIN_ATS_NAME=

# Candidatura spontanea pubblica (pagina /registrazione, senza annuncio associato).
# Entrambe obbligatorie: se mancano, il form mostra un errore invece di salvare
# il candidato senza organizzazione/proprietario.
PUBLIC_SPONTANEOUS_ORG_ID=
PUBLIC_SPONTANEOUS_USER_ID=

