generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  clerkOrganizationId String?              @unique
  absences            Absence[]
  applications        Application[]
  attendanceEntries   AttendanceEntry[]
  auditLogs           AuditLog[]
  calendarEvents      CalendarEvent[]
  candidates          Candidate[]
  cronofyAccounts     CronofyAccount[]
  documents           Document[]
  employees           Employee[]
  jobs                Job[]
  memberships         Membership[]
  invites             MembershipInvite[]
  onboardingTasks     OnboardingTask[]
  domains             OrganizationDomain[]
  reviews             Review[]
  reviewCycles        ReviewCycle[]
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole @default(RECRUITER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  entity         String
  entityId       String?
  action         AuditAction
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model MembershipInvite {
  id              String                 @id @default(uuid())
  organizationId  String
  email           String
  role            MembershipRole         @default(RECRUITER)
  status          MembershipInviteStatus @default(PENDING)
  invitedByUserId String
  token           String                 @unique
  expiresAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email, status])
  @@index([organizationId, status])
}

model Task {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  completed Boolean  @default(false)
}

model Candidate {
  id             String          @id @default(uuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  firstName      String
  lastName       String
  email          String
  phone          String?
  city           String
  role           String
  seniority      String
  sector         String
  expectedSalary Int?
  skills         String?
  status         String
  cvUrl          String?
  notes          String?
  province       String?
  education      String?
  organizationId String
  userId         String
  source         String?         @default("Diretto")
  
  // --- NUOVI CAMPI PER AI MATCHING ---
  resumeText        String?       @db.Text // Testo estratto dal CV
  matchingScore     Int?          // Score totale 0-100
  educationScore    Int?          // Breakdown Istruzione
  experienceScore   Int?          // Breakdown Esperienza
  keywordScore      Int?          // Breakdown Keyword
  recommendation    String?       // Es. 'Highly Recommended'
  matchedKeywords   String[]      // Liste di parole trovate
  missingKeywords   String[]      // Liste di parole mancanti
  // -------------------------------------

  applications   Application[]
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidateNotes CandidateNote[]
  interviews     Interview[]

  @@unique([organizationId, email])
  @@index([organizationId, userId])
  // Aggiungiamo un indice per ordinare rapidamente per score
  @@index([matchingScore(sort: Desc)]) 
}
model Application {
  id             String       @id @default(uuid())
  organizationId String
  candidateId    String
  jobId          String
  status         String       @default("Nuovo")
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  candidate      Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job            Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([organizationId])
}

model CandidateNote {
  id             String    @id @default(uuid())
  organizationId String
  candidateId    String
  authorId       String
  authorName     String
  type           NoteType  @default(NOTA)
  content        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@index([organizationId, createdAt])
}

model Interview {
  id                String           @id @default(uuid())
  organizationId    String
  candidateId       String
  jobId             String?
  recruiterId       String
  recruiterName     String
  type              InterviewType    @default(VIDEO)
  outcome           InterviewOutcome @default(PENDING)
  scheduledAt       DateTime
  duration          Int?
  location          String?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  cronofyCalendarId String?
  candidate         Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, scheduledAt])
  @@index([organizationId, scheduledAt])
  @@index([recruiterId, scheduledAt])
}

model Job {
  id                String        @id @default(uuid())
  userId            String
  organizationId    String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  title             String
  company           String
  location          String
  locationFormatted String?
  city              String?
  province          String?
  country           String?       @default("IT")
  postalCode        String?
  description       String
  requirements      String
  responsibilities  String?
  benefits          String?
  sector            String
  industry          String?
  mode              String
  status            String        @default("Aperto")
  experienceLevel   String?
  educationLevel    String?
  remoteType        String?
  salary            Int?
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String?       @default("EUR")
  salaryInterval    String?
  salaryText        String?
  applicationUrl    String?
  externalSource    String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  category          String?
  isActive          Boolean       @default(true)
  postedAt          DateTime?     @default(now())
  expiresAt         DateTime?
  postToIndeed      Boolean       @default(false)
  postToJooble      Boolean       @default(false)
  postToLinkedIn    Boolean       @default(false)
  applications      Application[]
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

model Employee {
  id                String            @id @default(uuid())
  organizationId    String
  firstName         String
  lastName          String
  email             String
  roleTitle         String
  department        String?
  managerName       String?
  hiredAt           DateTime?
  status            EmployeeStatus    @default(ONBOARDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  absences          Absence[]
  attendanceEntries AttendanceEntry[]
  documents         Document[]
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  onboardingTasks   OnboardingTask[]
  reviews           Review[]

  @@unique([organizationId, email])
  @@index([organizationId, status])
}

model OnboardingTask {
  id             String               @id @default(uuid())
  organizationId String
  employeeId     String
  title          String
  dueDate        DateTime?
  status         OnboardingTaskStatus @default(TODO)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  employee       Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([employeeId, status])
}

model ReviewCycle {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  startsAt       DateTime?
  endsAt         DateTime?
  status         ReviewCycleStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  reviews        Review[]
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model Review {
  id             String       @id @default(uuid())
  organizationId String
  employeeId     String
  reviewCycleId  String
  score          Int?
  summary        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewCycle    ReviewCycle  @relation(fields: [reviewCycleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, reviewCycleId])
  @@index([organizationId, reviewCycleId])
}

model Tour {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  city        String
  country     String
  title       String
  description String
  image       String?
  stops       Json

  @@unique([city, country])
}

model Token {
  tokens Int    @default(1000)
  userId String @id
}

model OrganizationDomain {
  id             String       @id @default(uuid())
  organizationId String
  domain         String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CronofyAccount {
  id              String       @id @default(uuid())
  organizationId  String
  userId          String
  cronofySub      String
  profileId       String?
  calendarId      String?
  accessTokenEnc  String
  refreshTokenEnc String
  expiresAt       DateTime?
  channelId       String?
  tzid            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([cronofySub])
  @@index([channelId])
}

model Absence {
  id                String        @id @default(uuid())
  organizationId    String
  employeeId        String
  requestedByUserId String
  type              AbsenceType
  status            AbsenceStatus @default(REQUESTED)
  startDate         DateTime
  endDate           DateTime
  notes             String?
  cronofyCalendarId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  employee          Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startDate])
  @@index([employeeId, startDate])
}

model AttendanceEntry {
  id              String       @id @default(uuid())
  organizationId  String
  employeeId      String
  date            DateTime
  minutesWorked   Int
  overtimeMinutes Int?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  employee        Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId, date])
}

model Document {
  id                 String                  @id @default(uuid())
  organizationId     String
  employeeId         String?
  title              String
  fileUrl            String
  signatureRequestId String?
  signatureStatus    DocumentSignatureStatus @default(DRAFT)
  signedFileUrl      String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  employee           Employee?               @relation(fields: [employeeId], references: [id])
  organization       Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([signatureRequestId])
}

model CalendarEvent {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  cronofyEventId String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startDate])
  @@index([userId, startDate])
}

enum MembershipRole {
  OWNER
  ADMIN
  RECRUITER
  MANAGER
  VIEWER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ACCESS_DENIED
}

enum NoteType {
  NOTA
  VALUTAZIONE
  COLLOQUIO
  FEEDBACK
}

enum InterviewType {
  PHONE
  VIDEO
  IN_PERSON
  ASSESSMENT
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  NO_SHOW
  RESCHEDULED
}

enum MembershipInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum EmployeeStatus {
  ACTIVE
  ONBOARDING
  OFFBOARDING
  INACTIVE
}

enum OnboardingTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ReviewCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AbsenceType {
  FERIE
  PERMESSO
  MALATTIA
  ALTRO
}

enum AbsenceStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum DocumentSignatureStatus {
  DRAFT
  SENT
  SIGNED
  DECLINED
  ERROR
}
